{
  "manifest_version": 2,
  "name": "Mindful Navigation",
  "version": "1.0.0",
  "description": "Practice intentional browsing with mindful questions and timers",

  "permissions": [
    "storage",
    "tabs",
    "webNavigation",
    "webRequest",
    "webRequestBlocking",
    "notifications",
    "<all_urls>"
  ],

  "background": {
    "scripts": ["browser-polyfill.js", "background.js"],
    "persistent": true
  },

  "content_scripts": [
    {
      "matches": ["<all_urls>"],
      "js": ["browser-polyfill.js", "content.js"],
      "css": ["styles/overlay.css"],
      "run_at": "document_start",
      "all_frames": false
    }
  ],

  "browser_action": {
    "default_popup": "popup/popup.html",
    "default_icon": {
      "48": "icons/icon-48.png",
      "96": "icons/icon-96.png"
    }
  },

  "options_ui": {
    "page": "options/options.html",
    "open_in_tab": true
  },

  "icons": {
    "48": "icons/icon-48.png",
    "96": "icons/icon-96.png"
  },

  "web_accessible_resources": [
    "styles/overlay.css",
    "browser-polyfill.js"
  ]
}
